# Family Orchestration Bot - Local Environment Template
# Copy this file to .env and fill your real values before running Google OAuth connect.

# Optional but recommended for backend logs
PYTHONUNBUFFERED=1

# Google Calendar OAuth configuration (required for /integrations/google-calendar/connect)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/integrations/google-calendar/callback

# Where users should be sent after OAuth callback success
GOOGLE_OAUTH_SUCCESS_REDIRECT_BASE_URL=http://127.0.0.1:5173
